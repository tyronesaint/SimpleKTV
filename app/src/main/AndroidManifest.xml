<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.tiletester">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.TileIconTester">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 可自定义透图文字 -->
        <service
            android:name=".TestTileCustomTransparent"
            android:exported="true"
            android:icon="@drawable/ic_tile_vector"
            android:label="自透"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <!-- 可自定义 Emoji -->
        <service
            android:name=".TestTileCustomEmoji"
            android:exported="true"
            android:icon="@drawable/ic_tile_vector"
            android:label="自Emoji"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <!-- 可自定义系统图标 -->
        <service
            android:name=".TestTileCustomSystem"
            android:exported="true"
            android:icon="@android:drawable/ic_menu_preferences"
            android:label="自系统"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <!-- 可自定义图片 -->
        <service
            android:name=".TestTileCustomImage"
            android:exported="true"
            android:icon="@drawable/ic_tile_vector"
            android:label="自图片"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

    </application>
</manifest>
